<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main app theme (applied after splash screen exits) -->
    <style name="Theme.MarathiCalendar" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/surface_white</item>
        <item name="android:statusBarColor">@color/saffron_primary</item>
        <item name="android:navigationBarColor">@color/surface_white</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen theme (set on Activity in AndroidManifest) -->
    <style name="Theme.MarathiCalendar.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/saffron_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.MarathiCalendar</item>
    </style>

</resources>
